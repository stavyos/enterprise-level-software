# Database Configuration (Development)
DB_HOST=localhost            # The host of the development database
DB_PORT=5430                 # The port of the development database
DB_USER=postgres             # The database username
DB_PASSWORD=your_password    # The database password
DB_NAME=postgres             # The database name

# EODHD API Configuration
EODHD_API_KEY=your_api_key   # Your EODHD API key

# Prefect Configuration
PREFECT_API_URL=http://127.0.0.1:4200/api       # API URL for the development Prefect server
PREFECT_PROFILES_PATH=./.prefect/profiles.toml  # Path to the Prefect profiles configuration
PREFECT_PROFILE=dev                              # The Prefect profile to use for development
