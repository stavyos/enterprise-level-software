{
  "name": "etl-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/etl-service/src",
  "projectType": "application",
  "targets": {
    "install": {},
    "test": {},
    "lint": {},
    "format": {},
    "build": {},
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m etl_service.etl.deploy_etls",
        "cwd": "{projectRoot}",
        "env": {
          "PYTHONPATH": "../../libs/db-client/src;../../libs/eodhd-client/src;src"
        }
      },
      "dependsOn": ["install"]
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t etl-service:local -f Dockerfile.etl .",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
