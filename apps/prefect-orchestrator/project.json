{
  "name": "prefect-orchestrator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/prefect-orchestrator/src",
  "projectType": "application",
  "targets": {
    "install": {},
    "test": {},
    "lint": {},
    "format": {},
    "build": {},
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run prefect server start --host 0.0.0.0",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["install"]
    },
    "worker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run prefect worker start --pool my-k8s-pool",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["install"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run prefect-orchestrator:run",
          "nx run prefect-orchestrator:worker"
        ],
        "parallel": true
      }
    }
  }
}
